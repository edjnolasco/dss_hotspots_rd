# ============================================================
# DSS_Hotspots_RD - .gitignore
# ============================================================

# -----------------------------
# Python cache / compiled files
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# -----------------------------
# Native / compiled extensions
# -----------------------------
*.so

# -----------------------------
# Virtual environments
# -----------------------------
.env
.env.*
.envrc
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# -----------------------------
# Packaging / build artifacts
# -----------------------------
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# -----------------------------
# Installer / packaging helpers
# -----------------------------
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------
# Testing / coverage / caches
# -----------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/
.dmypy.json
dmypy.json

# -----------------------------
# Jupyter / IPython
# -----------------------------
.ipynb_checkpoints/
profile_default/
ipython_config.py

# -----------------------------
# Streamlit
# -----------------------------
.streamlit/secrets.toml

# -----------------------------
# Logs / local databases
# -----------------------------
*.log
db.sqlite3
db.sqlite3-journal

# -----------------------------
# Editors / IDEs
# -----------------------------
.idea/
.vscode/
.spyderproject
.spyproject
.ropeproject

# -----------------------------
# OS / misc
# -----------------------------
.DS_Store
Thumbs.db

# -----------------------------
# Project-specific generated outputs
# -----------------------------
dss_outputs/
dss_outputs_presentacion/
releases/tmp/
*.tmp

# -----------------------------
# Optional local data files
# Keep the example dataset tracked, ignore heavy/private data
# -----------------------------
data/raw/
data/private/
data/intermediate/
data/exports/

# -----------------------------
# Optional local geo files
# Uncomment if you do NOT want to version large geojsons
# -----------------------------
# data/*.geojson
data/distrito_municipal_rd.json

# -----------------------------
# Optional notebook exports
# Uncomment if notebooks are only local working files
# -----------------------------
# *.ipynb

# -----------------------------
# Keep versioned releases tracked only if you want them in repo
# If releases will be managed through GitHub Releases, ignore ZIPs
# -----------------------------
releases/*.zip
data/distrito_municipal_rd.json
